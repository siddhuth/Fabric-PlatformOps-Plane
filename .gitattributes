# Auto-detect text files and normalize line endings
* text=auto

# Force LF for source files (prevents CRLF issues on Windows)
*.py text eol=lf
*.sh text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.tf text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.svg binary
